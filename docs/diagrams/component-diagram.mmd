        STORE --> RENDER
        RENDER --> PANE
        RENDER --> SIDEBAR
        RENDER --> TOOLTIP
        BINDER --> TOOLTIP
        AUTOGEN --> BINDER
    end

    subgraph Sources["Content Sources"]
        MD[(Markdown Files)]
        CATALOG[(retold-catalog.json)]
        KWIDX[(keyword-index.json)]
